{
  "name": "gitstar-extension",
  "displayName": "GitStar",
  "version": "1.0.0",
  "description": "Browse GitHub high-star projects",
  "author": "fuzheng",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "lint": "echo 'No linter configured yet'"
  },
  "dependencies": {
    "dompurify": "^3.4.7",
    "marked": "^18.0.4",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "wouter": "^3.10.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "0.0.258",
    "@types/dompurify": "^3.0.5",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "^10.5.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "typescript": "5.3.3",
    "vitest": "^4.1.7"
  },
  "manifest": {
    "host_permissions": [
      "https://api.github.com/*"
    ],
    "permissions": [
      "storage"
    ]
  }
}
